---
interface Props {
  /** Texto sin el "//": el prefijo lo pone el componente. */
  label: string;
  /** Id del <h2> oculto, para enlazarlo con aria-labelledby desde la <section>. */
  headingId?: string;
}

const { label, headingId } = Astro.props;
---

{
  /* El kicker es decorativo; el encabezado real va oculto para lectores de
     pantalla, de modo que la jerarquía h1 > h2 se mantenga sin duplicar texto
     visible. */
}
<h2 class="sr-only" id={headingId}>{label}</h2>
<div class="section-header" aria-hidden="true">// {label}</div>

<style>
  .section-header {
    font-family: var(--font-brand);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--accent);
    border-top: var(--border-strong) solid var(--accent-deep);
    padding-top: var(--space-5);
    margin-bottom: var(--space-6);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
