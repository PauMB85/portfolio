---
interface Props {
  tags: readonly string[];
  /** Variante visual explícita, alineada con las clases de components.css. */
  variant?: 'default' | 'muted';
}

const { tags, variant = 'default' } = Astro.props;
const cls = variant === 'muted' ? 'tag tag-muted' : 'tag';
---

<ul class="tags">
  {tags.map((tag) => <li class={cls}>{tag}</li>)}
</ul>

<style>
  /* Lista real en el marcado (es una enumeración), sin viñetas en pantalla. */
  .tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
