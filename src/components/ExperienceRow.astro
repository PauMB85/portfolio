---
interface Props {
  period: string;
  role: string;
  company: string;
  /** Qué se resolvió. Va en acento: es la línea que se escanea. */
  impact: string;
  /** El cómo: stack, contexto y alcance. */
  detail: string;
}

const { period, role, company, impact, detail } = Astro.props;
---

<article class="row">
  <p class="period">{period}</p>

  <div>
    <h3 class="company">{company}</h3>
    <p class="role">{role}</p>
  </div>

  <div class="body">
    <p class="impact">{impact}</p>
    <p class="detail">{detail}</p>
  </div>
</article>

<style>
  .row {
    display: grid;
    grid-template-columns: 200px 260px 1fr;
    gap: var(--space-5);
    padding: var(--space-5) 0;
    border-bottom: var(--border-w) solid var(--line);
    align-items: baseline;
  }

  .row p {
    margin: 0;
  }

  .period {
    font-family: var(--font-brand);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* La empresa manda en la columna; el cargo la matiza debajo. */
  .company {
    font-family: var(--font-brand);
    font-size: var(--text-md);
    font-weight: 600;
  }

  .role {
    font-family: var(--font-brand);
    font-size: var(--text-xs);
    color: var(--accent);
    margin-top: var(--space-1);
  }

  .body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .impact {
    font-size: var(--text-md);
    color: var(--text-body);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .detail {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @media (max-width: 900px) {
    .row {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
