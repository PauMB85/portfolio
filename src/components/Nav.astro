---
import { SITE } from '../data/site';
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);

// Anclas dentro de la misma página: no llevan base, son fragmentos.
const links = [
  { href: '#work', label: ui.nav.work },
  { href: '#experience', label: ui.nav.experience },
  { href: '#skills', label: ui.nav.skills },
  { href: '#contact', label: ui.nav.contact },
];
---

<nav class="nav">
  <p class="nav-brand">
    <span class="tilde">{SITE.brand.tilde}</span>{SITE.brand.stem}<span class="ext">{SITE.brand.ext}</span>
  </p>
  <div class="nav-links">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </div>
</nav>

<style>
  /* Altura fijada desde --nav-h (BaseLayout) para que el calc() del hero
     a pantalla completa sea exacto. */
  .nav {
    min-height: var(--nav-h);
    box-sizing: border-box;
  }

  .nav-brand {
    margin: 0;
  }

  /* components.css no cubre el focus de los enlaces del nav: se añade aquí
     para que el foco de teclado sea visible en toda la barra. */
  .nav-links a:focus-visible {
    outline: var(--border-strong) solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 600px) {
    .nav {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }
  }
</style>
