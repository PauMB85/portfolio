---
import Button from './Button.astro';
import Cursor from './Cursor.astro';
import { SITE } from '../data/site';
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);
---

<header class="hero">
  <h1>
    <span class="muted">{ui.hero.line1}</span><br />
    <span class="muted">{ui.hero.line2}</span><br />
    <span class="accent">{ui.hero.line3}</span><Cursor />
  </h1>

  <p class="lead">{ui.hero.lead}</p>

  <div class="actions">
    <Button variant="primary" href={`mailto:${SITE.email}`}>{ui.hero.primary}</Button>
    <Button variant="ghost" href="#work">{ui.hero.ghost}</Button>
  </div>
</header>

<style>
  .hero {
    /* Ocupa la pantalla menos la barra de navegación, y centra el contenido
       verticalmente. dvh y no vh: en móvil, vh ignora la barra del navegador
       y el hero quedaría cortado. */
    min-height: calc(100vh - var(--nav-h));
    min-height: calc(100dvh - var(--nav-h));
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-7) var(--space-8);
    gap: var(--space-5);
    max-width: 1000px;
    box-sizing: border-box;
  }

  h1 {
    font-size: var(--text-3xl);
    line-height: 1.25;
    text-wrap: pretty;
  }

  .muted {
    color: var(--text-muted);
  }

  .accent {
    color: var(--accent);
  }

  /* El cursor va pegado a la última línea, con un respiro. */
  h1 :global(.cursor) {
    margin-left: 12px;
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: var(--leading-body);
    max-width: 680px;
    margin: 0;
    text-wrap: pretty;
  }

  .actions {
    display: flex;
    gap: var(--space-4);
    margin-top: var(--space-2);
    flex-wrap: wrap;
  }

  @media (max-width: 720px) {
    .hero {
      padding: var(--space-7) var(--space-5);
    }

    h1 {
      font-size: var(--text-2xl);
    }
  }

  /* Pantallas bajas (portátiles pequeños, móvil apaisado): si el contenido no
     cabe, deja de forzar la altura completa antes que recortarlo. */
  @media (max-height: 600px) {
    .hero {
      min-height: 0;
      padding-block: var(--space-8);
    }
  }
</style>
