---
interface Props {
  metrics: readonly { value: string; caption: string }[];
}

const { metrics } = Astro.props;
---

<dl class="metrics">
  {
    metrics.map((m) => (
      <div class="metric">
        <dt class="value">{m.value}</dt>
        <dd class="caption">{m.caption}</dd>
      </div>
    ))
  }
</dl>

<style>
  /* <dl> porque es literalmente una lista de pares cifra/descripción. */
  .metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    border-top: var(--border-w) solid var(--line);
    padding-top: var(--space-4);
    margin: 0;
  }

  .value {
    font-family: var(--font-brand);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--accent);
  }

  .caption {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  @media (max-width: 720px) {
    .metrics {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
