---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { SITE } from '../data/site';
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const ui = t(locale);
const other: Locale = locale === 'en' ? 'es' : 'en';
---

<footer class="footer">
  <span>{SITE.brand.tilde}{SITE.brand.stem}{SITE.brand.ext} — {SITE.name}</span>

  {
    /* Escape de idioma. No es un selector con banderas: es un enlace con texto
       explícito, en el idioma de destino, para que quien caiga en la versión
       equivocada por la detección automática pueda salir. */
  }
  <a class="lang" href={getRelativeLocaleUrl(other)} hreflang={other} lang={other}>
    // {ui.otherLocale}
  </a>

  <span>© {SITE.year}</span>
</footer>

<style>
  .footer {
    padding: var(--space-6) var(--space-8);
    border-top: var(--border-w) solid var(--line);
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
    font-family: var(--font-brand);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .lang {
    color: var(--text-muted);
  }

  .lang:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .lang:focus-visible {
    outline: var(--border-strong) solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 600px) {
    .footer {
      padding: var(--space-5);
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
