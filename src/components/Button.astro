---
interface Props {
  /**
   * Variante explícita por string, no props booleanas.
   * Se corresponde 1:1 con las clases que ya expone components.css.
   */
  variant: 'primary' | 'ghost';
  href: string;
}

const { variant, href } = Astro.props;

// Los enlaces externos se detectan por el propio href en vez de con una prop
// booleana `external`: un dato que ya está en el href no debería repetirse.
const isExternal = /^https?:\/\//.test(href);
---

<a
  class:list={['btn', `btn-${variant}`]}
  href={href}
  {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  <span class="prompt" aria-hidden="true">$</span>
  <slot />
</a>
