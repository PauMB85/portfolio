---
import { getRelativeLocaleUrl, getAbsoluteLocaleUrl } from 'astro:i18n';
import '../styles/styles.css';
import { SITE } from '../data/site';
import { withBase, LOCALES } from '../i18n/utils';

/**
 * Router x-default.
 *
 * GitHub Pages es hosting estático: no hay servidor que lea Accept-Language,
 * así que la detección sólo puede ocurrir en el navegador. Para que eso no
 * dañe el SEO, esta página NO es la versión inglesa: /en/ y /es/ tienen su
 * propia URL indexable y ésta sólo reparte, declarada como x-default —
 * el caso de uso que Google documenta para páginas de selección de idioma.
 *
 * Sin JavaScript sigue siendo útil: los dos enlaces están en el HTML.
 */

const en = getRelativeLocaleUrl('en');
const es = getRelativeLocaleUrl('es');
const canonical = new URL(withBase('/'), Astro.site).href;

// Se interpola el base real para no escribir rutas a mano.
const routerScript = `
(function () {
  try {
    var stored = localStorage.getItem('pauh:lang');
    var lang = stored || navigator.language || 'en';
    var target = lang.toLowerCase().indexOf('es') === 0 ? ${JSON.stringify(es)} : ${JSON.stringify(en)};
    // replace() y no assign(): el router no debe dejar rastro en el historial,
    // o el botón "atrás" quedaría atrapado en un bucle.
    location.replace(target);
  } catch (e) {
    /* Sin localStorage (modo privado restrictivo): los enlaces siguen ahí. */
  }
})();
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{SITE.name} — portfolio</title>
    <meta
      name="description"
      content="Full-stack developer specialised in AI and blockchain. Choose your language / elige idioma."
    />
    <link rel="canonical" href={canonical} />

    {LOCALES.map((l) => <link rel="alternate" hreflang={l} href={getAbsoluteLocaleUrl(l)} />)}
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <link rel="icon" type="image/svg+xml" href={withBase('/assets/icon.svg')} />
    <meta name="theme-color" content="#14110c" />

    <script is:inline set:html={routerScript} />
  </head>

  <body>
    <main class="router">
      <p class="brand">
        <span class="tilde">{SITE.brand.tilde}</span>{SITE.brand.stem}<span class="ext"
          >{SITE.brand.ext}</span
        >
      </p>

      <h1 class="prompt-line">// choose a language · elige idioma</h1>

      <div class="links">
        <a class="btn btn-primary" href={en}><span class="prompt" aria-hidden="true">$</span> english</a>
        <a class="btn btn-ghost" href={es} lang="es"
          ><span class="prompt" aria-hidden="true">$</span> castellano</a
        >
      </div>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--surface-page);
    color: var(--text-body);
  }

  .router {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-5);
    padding: var(--space-8);
    max-width: 640px;
  }

  .brand {
    font-family: var(--font-brand);
    font-size: var(--text-lg);
    font-weight: 600;
    margin: 0;
  }

  .tilde {
    color: var(--gold-500);
  }

  .ext {
    color: var(--gold-300);
  }

  .prompt-line {
    font-family: var(--font-brand);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    color: var(--accent);
    margin: 0;
  }

  .links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>
