---
import { getRelativeLocaleUrl } from 'astro:i18n';
import '../styles/styles.css';
import PrimaryButton from '../components/PrimaryButton.astro';
import GhostButton from '../components/GhostButton.astro';
import { SITE } from '../data/site';
import { withBase } from '../i18n/utils';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — {SITE.name}</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href={withBase('/assets/icon.svg')} />
    <meta name="theme-color" content="#14110c" />
  </head>

  <body>
    <main class="notfound">
      <p class="kicker">// 404</p>
      <h1>No such file or directory</h1>
      <p class="lead">Esta ruta no existe. / This path does not exist.</p>
      <div class="links">
        <PrimaryButton href={getRelativeLocaleUrl('en')}>cd ~/en</PrimaryButton>
        <GhostButton href={getRelativeLocaleUrl('es')}>cd ~/es</GhostButton>
      </div>
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: var(--surface-page);
    color: var(--text-body);
  }

  .notfound {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-5);
    padding: var(--space-8);
    max-width: 640px;
  }

  .kicker {
    font-family: var(--font-brand);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--accent);
    margin: 0;
  }

  h1 {
    font-size: var(--text-2xl);
  }

  .lead {
    color: var(--text-muted);
    line-height: var(--leading-body);
    margin: 0;
  }

  .links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>
